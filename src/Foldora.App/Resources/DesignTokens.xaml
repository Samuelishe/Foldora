<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="PageBackgroundColor">#F6F9FD</Color>
    <Color x:Key="PageBackgroundBottomColor">#EEF4FB</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceSecondaryColor">#F8FAFD</Color>
    <Color x:Key="SurfaceTertiaryColor">#EEF3FA</Color>
    <Color x:Key="SurfaceAccentColor">#F3F8FF</Color>
    <Color x:Key="BorderColor">#DDE5F0</Color>
    <Color x:Key="BorderSoftColor">#E8EEF7</Color>
    <Color x:Key="BorderStrongColor">#C9D4E4</Color>
    <Color x:Key="TextPrimaryColor">#102033</Color>
    <Color x:Key="TextSecondaryColor">#5D6B7F</Color>
    <Color x:Key="TextDisabledColor">#9AA6B8</Color>
    <Color x:Key="AccentColor">#2563EB</Color>
    <Color x:Key="AccentHoverColor">#1D4ED8</Color>
    <Color x:Key="AccentPressedColor">#1E40AF</Color>
    <Color x:Key="AccentCyanColor">#06B6D4</Color>
    <Color x:Key="AccentVioletColor">#7C3AED</Color>
    <Color x:Key="AccentSoftColor">#EAF3FF</Color>
    <Color x:Key="AccentSoftCyanColor">#E8FBFF</Color>
    <Color x:Key="AccentSoftBorderColor">#BBD7FF</Color>
    <Color x:Key="OnAccentColor">#FFFFFF</Color>
    <Color x:Key="DangerColor">#B42318</Color>
    <Color x:Key="DangerHoverColor">#971B12</Color>
    <Color x:Key="DangerBackgroundColor">#FFF1F1</Color>
    <Color x:Key="DangerBorderColor">#F4B8B8</Color>
    <Color x:Key="SuccessColor">#16794C</Color>
    <Color x:Key="SuccessBackgroundColor">#EAFBF1</Color>
    <Color x:Key="SuccessBorderColor">#B9E8CE</Color>
    <Color x:Key="WarningColor">#A15C07</Color>
    <Color x:Key="WarningBackgroundColor">#FFF7E8</Color>
    <Color x:Key="WarningBorderColor">#F1D49B</Color>
    <Color x:Key="FocusColor">#3B82F6</Color>
    <Color x:Key="DisabledSurfaceColor">#EEF0F3</Color>

    <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{DynamicResource PageBackgroundColor}" Offset="0" />
        <GradientStop Color="{DynamicResource PageBackgroundBottomColor}" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceSecondaryBrush" Color="{DynamicResource SurfaceSecondaryColor}" />
    <SolidColorBrush x:Key="SurfaceTertiaryBrush" Color="{DynamicResource SurfaceTertiaryColor}" />
    <SolidColorBrush x:Key="SurfaceAccentBrush" Color="{DynamicResource SurfaceAccentColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
    <SolidColorBrush x:Key="BorderSoftBrush" Color="{DynamicResource BorderSoftColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{DynamicResource BorderStrongColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{DynamicResource TextDisabledColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{DynamicResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentCyanBrush" Color="{DynamicResource AccentCyanColor}" />
    <SolidColorBrush x:Key="AccentVioletBrush" Color="{DynamicResource AccentVioletColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{DynamicResource AccentSoftColor}" />
    <SolidColorBrush x:Key="AccentSoftCyanBrush" Color="{DynamicResource AccentSoftCyanColor}" />
    <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="{DynamicResource AccentSoftBorderColor}" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="{DynamicResource OnAccentColor}" />
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource AccentCyanColor}" Offset="0" />
        <GradientStop Color="{DynamicResource AccentColor}" Offset="0.55" />
        <GradientStop Color="{DynamicResource AccentVioletColor}" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentHoverGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0891B2" Offset="0" />
        <GradientStop Color="{DynamicResource AccentHoverColor}" Offset="0.62" />
        <GradientStop Color="#6D28D9" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentSoftGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{DynamicResource AccentSoftCyanColor}" Offset="0" />
        <GradientStop Color="{DynamicResource AccentSoftColor}" Offset="0.62" />
        <GradientStop Color="#F4F0FF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeaderSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="{DynamicResource AccentSoftCyanColor}" Offset="0.48" />
        <GradientStop Color="#F6F1FF" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DangerBrush" Color="{DynamicResource DangerColor}" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{DynamicResource DangerHoverColor}" />
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="{DynamicResource DangerBackgroundColor}" />
    <SolidColorBrush x:Key="DangerBorderBrush" Color="{DynamicResource DangerBorderColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="{DynamicResource SuccessBackgroundColor}" />
    <SolidColorBrush x:Key="SuccessBorderBrush" Color="{DynamicResource SuccessBorderColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{DynamicResource WarningBackgroundColor}" />
    <SolidColorBrush x:Key="WarningBorderBrush" Color="{DynamicResource WarningBorderColor}" />
    <SolidColorBrush x:Key="FocusBrush" Color="{DynamicResource FocusColor}" />
    <SolidColorBrush x:Key="DisabledSurfaceBrush" Color="{DynamicResource DisabledSurfaceColor}" />

    <sys:Double x:Key="Spacing4">4</sys:Double>
    <sys:Double x:Key="Spacing8">8</sys:Double>
    <sys:Double x:Key="Spacing12">12</sys:Double>
    <sys:Double x:Key="Spacing16">16</sys:Double>
    <sys:Double x:Key="Spacing20">20</sys:Double>
    <sys:Double x:Key="Spacing24">24</sys:Double>
    <sys:Double x:Key="Spacing32">32</sys:Double>

    <Thickness x:Key="PagePadding">22</Thickness>
    <Thickness x:Key="SectionSpacing">0,0,0,16</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="PanelPadding">20</Thickness>
    <Thickness x:Key="PageHeaderPadding">22,20</Thickness>
    <Thickness x:Key="EmptyStatePadding">22</Thickness>
    <Thickness x:Key="StatusPillPadding">10,4</Thickness>
    <Thickness x:Key="PathRowPadding">12</Thickness>
    <Thickness x:Key="SettingsTabHeaderPadding">10,6</Thickness>
    <Thickness x:Key="SettingsTabContentPadding">18</Thickness>
    <Thickness x:Key="FieldBottomMargin">0,0,0,8</Thickness>
    <Thickness x:Key="ButtonInlineMargin">0,0,8,8</Thickness>

    <CornerRadius x:Key="RadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">12</CornerRadius>

    <sys:Double x:Key="ControlHeight">34</sys:Double>
    <sys:Double x:Key="IconButtonSize">32</sys:Double>
    <sys:Double x:Key="PreviewBoxSize">52</sys:Double>
    <sys:Double x:Key="PreviewImageSize">50</sys:Double>
    <Thickness x:Key="StandardBorderThickness">1</Thickness>
</ResourceDictionary>
