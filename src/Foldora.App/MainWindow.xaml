<Window x:Class="Foldora.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Foldora"
        Height="780"
        Width="980"
        MinHeight="640"
        MinWidth="780"
        WindowStyle="None"
        ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PageBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button ToolTip="{Binding L.Settings}"
                            AutomationProperties.Name="{Binding L.Settings}"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Margin="0,0,6,0">
                        <Viewbox Width="16" Height="16">
                            <Path Fill="{DynamicResource TextPrimaryBrush}"
                                  Data="F0 M9,1 L12,1 L12.45,3.1 C13.05,3.28 13.62,3.52 14.15,3.84 L15.95,2.82 L17.38,4.25 L16.34,6.05 C16.66,6.58 16.9,7.15 17.08,7.75 L19,8.28 L19,10.72 L17.08,11.25 C16.9,11.85 16.66,12.42 16.34,12.95 L17.38,14.75 L15.95,16.18 L14.15,15.16 C13.62,15.48 13.05,15.72 12.45,15.9 L12,18 L9,18 L8.55,15.9 C7.95,15.72 7.38,15.48 6.85,15.16 L5.05,16.18 L3.62,14.75 L4.66,12.95 C4.34,12.42 4.1,11.85 3.92,11.25 L2,10.72 L2,8.28 L3.92,7.75 C4.1,7.15 4.34,6.58 4.66,6.05 L3.62,4.25 L5.05,2.82 L6.85,3.84 C7.38,3.52 7.95,3.28 8.55,3.1 Z M10.5,6.5 C8.84,6.5 7.5,7.84 7.5,9.5 C7.5,11.16 8.84,12.5 10.5,12.5 C12.16,12.5 13.5,11.16 13.5,9.5 C13.5,7.84 12.16,6.5 10.5,6.5 Z" />
                        </Viewbox>
                    </Button>
                    <Button Content="—"
                            ToolTip="{Binding L.Minimize}"
                            Click="OnMinimizeClick"
                            Style="{StaticResource TitleBarButtonStyle}" />
                    <Button x:Name="MaximizeRestoreButton"
                            Content="□"
                            ToolTip="{Binding L.Maximize}"
                            Click="OnMaximizeRestoreClick"
                            Style="{StaticResource TitleBarButtonStyle}" />
                    <Button Content="×"
                            ToolTip="{Binding L.Close}"
                            Click="OnCloseClick"
                            Style="{StaticResource TitleBarButtonStyle}"
                            FontSize="18" />
                </StackPanel>

                <TextBlock Text="{Binding L.AppTitle}"
                           Style="{StaticResource WindowTitleTextStyle}"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="{DynamicResource PagePadding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,18">
                <TextBlock Text="{Binding L.PageTitle}"
                           Style="{StaticResource PageTitleTextStyle}"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding L.PageSubtitle}"
                           Style="{StaticResource SecondaryBodyTextStyle}"
                           TextWrapping="Wrap" />
                <WrapPanel Margin="0,10,0,0">
                    <TextBlock Text="{Binding ExplorerIntegrationStatusLabel}"
                               Style="{StaticResource SecondaryBodyTextStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <Button Content="{Binding L.ManageInSettings}"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="140" />
                </WrapPanel>
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <StackPanel Margin="{DynamicResource SectionSpacing}">
                        <TextBlock Text="{Binding L.MenuSettings}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding L.MenuTitle}"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="280"
                                     MaxWidth="520"
                                     HorizontalAlignment="Left" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="{DynamicResource SectionSpacing}">
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="{Binding L.MenuEntries}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0" />
                            <Button DockPanel.Dock="Right"
                                    Content="{Binding L.AddEntry}"
                                    Command="{Binding AddEntryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="140"
                                    HorizontalAlignment="Right" />
                            <Button DockPanel.Dock="Right"
                                    Content="{Binding L.AddGroup}"
                                    Command="{Binding AddGroupCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="140"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right" />
                        </DockPanel>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SectionContainerStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasEntries}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding L.EmptyTitle}"
                                           Style="{StaticResource GroupTitleTextStyle}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding L.EmptyDescription}"
                                           Style="{StaticResource SecondaryBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,14" />
                                <Button Content="{Binding L.AddEntry}"
                                        Command="{Binding AddEntryCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="140"
                                        HorizontalAlignment="Left" />
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding EntryGroups}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasEntries}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GroupContainerStyle}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Title}"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource GroupTitleTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRootSection}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <TextBox Grid.Column="0"
                                                         Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         FontWeight="SemiBold"
                                                         VerticalAlignment="Center">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRootSection}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding EntryCountText}"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" />

                                                <Button Grid.Column="2"
                                                        Content="×"
                                                        Command="{Binding DeleteGroupCommand}"
                                                        ToolTip="{Binding DeleteGroupText}"
                                                        Margin="12,0,0,0"
                                                        FontSize="16">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerIconButtonStyle}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanDeleteGroup}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>

                                            <Border Style="{StaticResource DangerBannerStyle}"
                                                    Margin="0,0,0,10"
                                                    Visibility="{Binding IsDeleteConfirmationVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               Text="{Binding DataContext.L.DeleteGroupPrompt, RelativeSource={RelativeSource AncestorType=Window}}"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,12,0" />
                                                    <Button DockPanel.Dock="Right"
                                                            Content="{Binding CancelText}"
                                                            Command="{Binding CancelDeleteGroupCommand}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Margin="8,0,0,0" />
                                                    <Button DockPanel.Dock="Right"
                                                            Content="{Binding ConfirmDeleteGroupText}"
                                                            Command="{Binding ConfirmDeleteGroupCommand}"
                                                            Style="{StaticResource DangerButtonStyle}" />
                                                </DockPanel>
                                            </Border>

                                        <ItemsControl ItemsSource="{Binding Entries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource CardContainerStyle}"
                                                            ToolTip="{Binding Id}">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.Style>
                                                                    <Style TargetType="Grid">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="64" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border Grid.Column="0"
                                                                        Style="{StaticResource PreviewBoxStyle}">
                                                                    <Image Source="{Binding IconPreview}"
                                                                           Width="{DynamicResource PreviewImageSize}"
                                                                           Height="{DynamicResource PreviewImageSize}"
                                                                           Stretch="Uniform" />
                                                                </Border>

                                                                <StackPanel Grid.Column="1"
                                                                            VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding CompactTitle}"
                                                                               Style="{StaticResource GroupTitleTextStyle}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Style="{StaticResource SecondaryBodyTextStyle}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Margin="0,4,0,0">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding StringFormat="{}{0}{1}">
                                                                                <Binding Path="DataContext.L.FolderNameSummaryLabel" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                                <Binding Path="CompactFolderName" />
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                    <TextBlock Text="{Binding IconState}"
                                                                               Style="{StaticResource CaptionTextStyle}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Margin="0,4,0,0" />
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="2"
                                                                            Orientation="Horizontal"
                                                                            VerticalAlignment="Center"
                                                                            Margin="14,0,0,0">
                                                                    <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              ToolTip="{Binding DataContext.L.EntryEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              Margin="0,0,8,0" />
                                                                    <Button Content="{Binding DataContext.L.Edit, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            Command="{Binding EditCommand}"
                                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                                            MinWidth="96"
                                                                            Margin="0,0,8,0" />
                                                                    <Button Content="{Binding DataContext.L.Delete, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            Command="{Binding RemoveCommand}"
                                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                                            MinWidth="96" />
                                                                </StackPanel>
                                                            </Grid>

                                                            <Grid>
                                                                <Grid.Style>
                                                                    <Style TargetType="Grid">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="64" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Border Grid.Column="0"
                                                                        Style="{StaticResource PreviewBoxStyle}">
                                                                    <Image Source="{Binding IconPreview}"
                                                                           Width="{DynamicResource PreviewImageSize}"
                                                                           Height="{DynamicResource PreviewImageSize}"
                                                                           Stretch="Uniform" />
                                                                </Border>

                                                                <StackPanel Grid.Column="1">
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="170" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <TextBlock Grid.Row="0"
                                                                                   Grid.Column="0"
                                                                                   Text="{Binding DataContext.L.EntryDisplayName, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                   Style="{StaticResource FieldLabelStyle}" />
                                                                        <TextBox Grid.Row="0"
                                                                                 Grid.Column="1"
                                                                                 Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Margin="0,0,14,6"
                                                                                 MinWidth="220" />

                                                                        <TextBlock Grid.Row="1"
                                                                                   Grid.Column="0"
                                                                                   Text="{Binding DataContext.L.EntryFolderName, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                   Style="{StaticResource FieldLabelStyle}" />
                                                                        <TextBox Grid.Row="1"
                                                                                 Grid.Column="1"
                                                                                 Text="{Binding DefaultFolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                 Margin="0,0,14,6"
                                                                                 MinWidth="220" />

                                                                        <CheckBox Grid.Row="2"
                                                                                  Grid.Column="1"
                                                                                  Content="{Binding DataContext.L.EntryEnabled, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  Margin="0,2,0,8" />

                                                                        <TextBlock Grid.Row="3"
                                                                                   Grid.Column="0"
                                                                                   Text="{Binding DataContext.L.EntryIcon, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                   Style="{StaticResource FieldLabelStyle}"
                                                                                   Margin="0,0,10,0" />
                                                                        <TextBlock Grid.Row="3"
                                                                                   Grid.Column="1"
                                                                                   Text="{Binding IconState}"
                                                                                   Style="{StaticResource SecondaryBodyTextStyle}"
                                                                                   TextWrapping="Wrap"
                                                                                   VerticalAlignment="Center"
                                                                                   Margin="0,0,14,0" />

                                                                        <StackPanel Grid.Row="0"
                                                                                    Grid.RowSpan="4"
                                                                                    Grid.Column="2"
                                                                                    Orientation="Vertical"
                                                                                    VerticalAlignment="Top">
                                                                            <Button Content="{Binding DataContext.L.ChooseIcon, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    Command="{Binding ChooseIconCommand}"
                                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                                    MinWidth="112"
                                                                                    Margin="0,0,0,8" />
                                                                            <Button Content="{Binding DataContext.L.Done, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    Command="{Binding FinishEditingCommand}"
                                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                                    MinWidth="112"
                                                                                    Margin="0,0,0,8" />
                                                                            <Button Content="{Binding DataContext.L.Delete, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    Command="{Binding RemoveCommand}"
                                                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                                                    MinWidth="112" />
                                                                        </StackPanel>
                                                                    </Grid>

                                                                    <ItemsControl ItemsSource="{Binding InlineErrors}"
                                                                                  Visibility="{Binding HasInlineErrors, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                  Margin="0,10,0,0">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding}"
                                                                                           Style="{StaticResource ValidationErrorTextStyle}"
                                                                                           TextWrapping="Wrap"
                                                                                           Margin="0,0,0,4" />
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                            <Button Content="{Binding AddEntryText}"
                                                    Command="{Binding AddEntryCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    MinWidth="150"
                                                    HorizontalAlignment="Left"
                                                    Margin="64,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <DockPanel Grid.Row="2"
                       Margin="0,16,0,14">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding UnsavedChangesText}"
                           Style="{StaticResource SecondaryBodyTextStyle}"
                           VerticalAlignment="Center"
                           />
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="{Binding L.Reload}"
                            Command="{Binding ReloadCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="160"
                            Margin="0,0,8,0" />
                    <Button Content="{Binding L.Save}"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="3"
                    Style="{StaticResource StatusBannerStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusTextStyle}"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <ItemsControl ItemsSource="{Binding Errors}"
                                  Visibility="{Binding HasValidationErrors, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Style="{StaticResource ValidationErrorTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
