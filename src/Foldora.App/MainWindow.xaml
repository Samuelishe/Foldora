<Window x:Class="Foldora.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Foldora" Height="700" Width="980"
        MinHeight="560" MinWidth="760">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Foldora"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,18" />

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Название меню:"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="280" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Пункты меню:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Entries}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      RowHeight="62">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Preview"
                                            Width="72">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="52"
                                        Height="52"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"
                                        Background="#FAFAFA"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Image Source="{Binding IconPreview}"
                                           Width="50"
                                           Height="50"
                                           Stretch="Uniform" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridCheckBoxColumn Header="Вкл."
                                            Width="56"
                                            Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Header="DisplayName"
                                        Width="2*"
                                        Binding="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Header="DefaultFolderName"
                                        Width="2*"
                                        Binding="{Binding DefaultFolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Header="EntryId"
                                        Width="2*"
                                        IsReadOnly="True"
                                        Binding="{Binding Id}" />
                    <DataGridTextColumn Header="Иконка"
                                        Width="2*"
                                        IsReadOnly="True"
                                        Binding="{Binding IconState}" />
                    <DataGridTemplateColumn Header=""
                                            Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Выбрать .ico"
                                        Command="{Binding ChooseIconCommand}"
                                        Padding="8,2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header=""
                                            Width="84">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить"
                                        Command="{Binding RemoveCommand}"
                                        Padding="8,2" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <GroupBox Grid.Row="3"
                  Header="Интеграция с Проводником"
                  Margin="0,16,0,0"
                  Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding ExplorerIntegrationStatusText, StringFormat=Статус: {0}}"
                           Margin="0,0,0,8" />

                <WrapPanel Grid.Row="1">
                    <Button Content="Проверить план"
                            Command="{Binding DryRunCommand}"
                            MinWidth="120"
                            Margin="0,0,8,8" />
                    <Button Content="Включить меню Проводника"
                            Command="{Binding RegisterExplorerCommand}"
                            MinWidth="180"
                            Margin="0,0,8,8" />
                    <Button Content="Отключить меню Проводника"
                            Command="{Binding UnregisterExplorerCommand}"
                            MinWidth="190"
                            Margin="0,0,8,8" />
                    <CheckBox Content="Я понимаю, что список пунктов будет очищен"
                              IsChecked="{Binding IsResetConfirmed, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              Margin="8,0,8,8" />
                    <Button Content="Сбросить меню"
                            Command="{Binding ResetMenuCommand}"
                            MinWidth="120"
                            Margin="0,0,0,8" />
                </WrapPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,16,0,12">
            <Button Content="+ Добавить пункт"
                    Command="{Binding AddEntryCommand}"
                    MinWidth="140"
                    Margin="0,0,8,0" />
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    MinWidth="120"
                    Margin="0,0,8,0" />
            <Button Content="Отменить изменения"
                    Command="{Binding ReloadCommand}"
                    MinWidth="160" />
            <TextBlock Text="{Binding HasUnsavedChanges, StringFormat=Несохранённые изменения: {0}}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0" />
        </StackPanel>

        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap" />
            <ItemsControl Grid.Row="1"
                          ItemsSource="{Binding OperationDetails}"
                          Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextWrapping="Wrap"
                                   Foreground="#333333"
                                   Margin="0,0,0,4" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl Grid.Row="2"
                          ItemsSource="{Binding Errors}"
                          Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextWrapping="Wrap"
                                   Foreground="#B00020"
                                   Margin="0,0,0,4" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</Window>
