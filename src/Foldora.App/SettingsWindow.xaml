<Window x:Class="Foldora.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="360"
        Height="260"
        MinWidth="320"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PageBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="{DynamicResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Настройки"
                   Style="{StaticResource SectionTitleStyle}"
                   Margin="0,0,0,18" />

        <Border Grid.Row="1"
                Style="{StaticResource SectionContainerStyle}">
            <StackPanel>
            <TextBlock Text="Язык приложения:"
                       Style="{StaticResource FieldLabelStyle}"
                       Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding AvailableLanguages}"
                      SelectedValue="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Code"
                      DisplayMemberPath="DisplayName"
                      Width="180"
                      HorizontalAlignment="Left" />
            <TextBlock Text="Некоторые изменения языка могут применяться после перезапуска."
                       Style="{StaticResource SecondaryBodyTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0" />
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource StatusTextStyle}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SuccessBrush}"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="96"
                    Margin="0,0,8,0" />
            <Button Content="Закрыть"
                    Click="OnCloseClick"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="96" />
        </StackPanel>
    </Grid>
</Window>
