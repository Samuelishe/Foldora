<Window x:Class="Foldora.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding L.Settings}"
        Width="520"
        Height="400"
        MinWidth="420"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        ShowInTaskbar="False"
        Background="{DynamicResource PageBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="{DynamicResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding L.Settings}"
                   Style="{StaticResource SectionTitleStyle}"
                   Margin="0,0,0,18" />

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,16">
            <StackPanel>
                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L.SettingsLanguageLabel}"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,0,0,8" />
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedValue="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Code"
                                  DisplayMemberPath="DisplayName"
                                  MinWidth="180"
                                  MaxWidth="280"
                                  HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding L.SettingsLanguageRestartNote}"
                                   Style="{StaticResource SecondaryBodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource StatusTextStyle}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{Binding L.Save}"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="96"
                    Margin="0,0,8,0" />
            <Button Content="{Binding L.Close}"
                    Click="OnCloseClick"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="96" />
        </StackPanel>
    </Grid>
</Window>
