<Window x:Class="Foldora.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding L.Settings}"
        Width="760"
        Height="600"
        MinWidth="720"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        ShowInTaskbar="False"
        Background="{DynamicResource PageBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="{DynamicResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PageHeaderContainerStyle}">
            <TextBlock Text="{Binding L.Settings}"
                       Style="{StaticResource PageTitleTextStyle}" />
        </Border>

        <TabControl Grid.Row="1"
                    Style="{StaticResource SettingsTabControlStyle}"
                    ItemContainerStyle="{StaticResource SettingsTabItemStyle}"
                    Margin="0,0,0,16">
            <TabItem Header="{Binding L.SettingsTabApplication}">
                <StackPanel>
                    <TextBlock Text="{Binding L.SettingsLanguageLabel}"
                               Style="{StaticResource FieldLabelStyle}"
                               Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding AvailableLanguages}"
                              SelectedValue="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Code"
                              DisplayMemberPath="DisplayName"
                              MinWidth="180"
                              MaxWidth="280"
                              HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding L.SettingsLanguageRestartNote}"
                               Style="{StaticResource SecondaryBodyTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusTextStyle}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SuccessBrush}"
                               Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Margin="0,10,0,0" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{Binding L.SettingsTabExplorerMenu}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <TextBlock Text="{Binding L.ExplorerMenuSection}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="?"
                                       AutomationProperties.Name="{Binding L.HelpTooltip}"
                                       Style="{StaticResource HelpInfoGlyphStyle}">
                                <TextBlock.ToolTip>
                                    <TextBlock Text="{Binding L.ExplorerMenuHelpTooltip}"
                                               Style="{StaticResource HelpTooltipTextStyle}" />
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>
                        <Border Style="{StaticResource StatusPillStyle}"
                                Margin="0,0,0,10">
                            <TextBlock Text="{Binding ExplorerIntegrationStatusLabel}"
                                       Style="{StaticResource CaptionTextStyle}"
                                       TextWrapping="Wrap" />
                        </Border>
                        <TextBlock Text="{Binding L.ExplorerActionsApplyImmediately}"
                                   Style="{StaticResource SecondaryBodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding L.SaveOrDiscardBeforeExplorer}"
                                   Style="{StaticResource SecondaryBodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <WrapPanel>
                            <Button Content="{Binding L.PreviewChanges}"
                                    Command="{Binding DryRunCommand}"
                                    Style="{StaticResource InlineActionButtonStyle}"
                                    Margin="{DynamicResource ButtonInlineMargin}">
                                <Button.ToolTip>
                                    <TextBlock Text="{Binding L.PreviewChangesTooltip}"
                                               Style="{StaticResource HelpTooltipTextStyle}" />
                                </Button.ToolTip>
                            </Button>
                            <TextBlock Text="?"
                                       AutomationProperties.Name="{Binding L.HelpTooltip}"
                                       Style="{StaticResource HelpInfoGlyphStyle}"
                                       Margin="0,8,12,8">
                                <TextBlock.ToolTip>
                                    <TextBlock Text="{Binding L.PreviewChangesTooltip}"
                                               Style="{StaticResource HelpTooltipTextStyle}" />
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <Button Content="{Binding L.RegisterExplorer}"
                                    Command="{Binding RegisterExplorerCommand}"
                                    Style="{StaticResource InlineActionButtonStyle}"
                                    Margin="{DynamicResource ButtonInlineMargin}" />
                            <Button Content="{Binding L.UnregisterExplorer}"
                                    Command="{Binding UnregisterExplorerCommand}"
                                    Style="{StaticResource InlineActionButtonStyle}"
                                    Margin="{DynamicResource ButtonInlineMargin}" />
                        </WrapPanel>

                        <ItemsControl ItemsSource="{Binding Errors}"
                                      Visibility="{Binding HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Style="{StaticResource ValidationErrorTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Expander Header="{Binding L.TechnicalDetails}"
                                  IsExpanded="{Binding ShowTechnicalDetails, Mode=TwoWay}"
                                  Visibility="{Binding HasTechnicalDetails, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  Margin="0,8,0,0">
                            <ItemsControl ItemsSource="{Binding TechnicalDetails}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Style="{StaticResource SecondaryBodyTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding L.SettingsTabInstallation}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <TextBlock Text="{Binding L.InstallationSection}"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="?"
                                       AutomationProperties.Name="{Binding L.HelpTooltip}"
                                       Style="{StaticResource HelpInfoGlyphStyle}">
                                <TextBlock.ToolTip>
                                    <TextBlock Text="{Binding L.InstallationPathsHelpTooltip}"
                                               Style="{StaticResource HelpTooltipTextStyle}" />
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </StackPanel>

                        <Border Style="{StaticResource PathRowContainerStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding L.InstalledAppPath}"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="{Binding InstalledAppPath}"
                                           ToolTip="{Binding InstalledAppPath}"
                                           Style="{StaticResource SecondaryBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,12,0" />
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button Content="{Binding L.OpenFolder}"
                                            Command="{Binding OpenInstalledAppPathCommand}"
                                            Style="{StaticResource InlineActionButtonStyle}"
                                            Margin="0,0,8,0">
                                        <Button.ToolTip>
                                            <TextBlock Text="{Binding L.OpenFolderTooltip}"
                                                       Style="{StaticResource HelpTooltipTextStyle}" />
                                        </Button.ToolTip>
                                    </Button>
                                    <Button Content="{Binding L.CopyPath}"
                                            Command="{Binding CopyInstalledAppPathCommand}"
                                            Style="{StaticResource InlineActionButtonStyle}">
                                        <Button.ToolTip>
                                            <TextBlock Text="{Binding L.CopyPathTooltip}"
                                                       Style="{StaticResource HelpTooltipTextStyle}" />
                                        </Button.ToolTip>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PathRowContainerStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding L.UserDataPath}"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="{Binding UserDataPath}"
                                           ToolTip="{Binding UserDataPath}"
                                           Style="{StaticResource SecondaryBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,12,0" />
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button Content="{Binding L.OpenFolder}"
                                            Command="{Binding OpenUserDataPathCommand}"
                                            Style="{StaticResource InlineActionButtonStyle}"
                                            Margin="0,0,8,0">
                                        <Button.ToolTip>
                                            <TextBlock Text="{Binding L.OpenFolderTooltip}"
                                                       Style="{StaticResource HelpTooltipTextStyle}" />
                                        </Button.ToolTip>
                                    </Button>
                                    <Button Content="{Binding L.CopyPath}"
                                            Command="{Binding CopyUserDataPathCommand}"
                                            Style="{StaticResource InlineActionButtonStyle}">
                                        <Button.ToolTip>
                                            <TextBlock Text="{Binding L.CopyPathTooltip}"
                                                       Style="{StaticResource HelpTooltipTextStyle}" />
                                        </Button.ToolTip>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource PathRowContainerStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding L.CurrentCommandHost}"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Text="{Binding CurrentCommandHostPath}"
                                           ToolTip="{Binding CurrentCommandHostPath}"
                                           Style="{StaticResource SecondaryBodyTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,12,0" />
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Orientation="Horizontal">
                                    <Button Content="{Binding L.OpenFolder}"
                                            Command="{Binding OpenCommandHostPathCommand}"
                                            Style="{StaticResource InlineActionButtonStyle}"
                                            Margin="0,0,8,0">
                                        <Button.ToolTip>
                                            <TextBlock Text="{Binding L.OpenLocationTooltip}"
                                                       Style="{StaticResource HelpTooltipTextStyle}" />
                                        </Button.ToolTip>
                                    </Button>
                                    <Button Content="{Binding L.CopyPath}"
                                            Command="{Binding CopyCommandHostPathCommand}"
                                            Style="{StaticResource InlineActionButtonStyle}">
                                        <Button.ToolTip>
                                            <TextBlock Text="{Binding L.CopyPathTooltip}"
                                                       Style="{StaticResource HelpTooltipTextStyle}" />
                                        </Button.ToolTip>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="{Binding L.MenuHostServiceNote}"
                                   Style="{StaticResource SecondaryBodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding L.UninstallHint}"
                                   Style="{StaticResource SecondaryBodyTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="{Binding L.SettingsTabHelpAbout}">
                <StackPanel>
                    <TextBlock Text="{Binding L.HelpAboutSection}"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding L.HelpAboutSummary}"
                               Style="{StaticResource SecondaryBodyTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <Button Content="{Binding L.OpenHelpAbout}"
                            Command="{Binding OpenHelpCommand}"
                            Style="{StaticResource InlineActionButtonStyle}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </TabItem>

            <TabItem Header="{Binding L.SettingsTabDangerZone}">
                <Border Style="{StaticResource DangerBannerStyle}"
                        Margin="0">
                    <StackPanel>
                        <TextBlock Text="{Binding L.DangerZone}"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Foreground="{DynamicResource DangerBrush}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding L.ResetDescription}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding L.ResetIconNote}"
                                   Style="{StaticResource SecondaryBodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <CheckBox Content="{Binding L.ResetConfirm}"
                                  IsChecked="{Binding IsResetConfirmed, Mode=TwoWay}"
                                  Margin="0,0,0,10" />
                        <Button Content="{Binding L.ResetMenu}"
                                Command="{Binding ResetMenuCommand}"
                                Style="{StaticResource DangerButtonStyle}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,2,0,0">
            <Button Content="{Binding L.Save}"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    MinWidth="96"
                    Margin="0,0,8,0" />
            <Button Content="{Binding L.Close}"
                    Click="OnCloseClick"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="96" />
        </StackPanel>
    </Grid>
</Window>
