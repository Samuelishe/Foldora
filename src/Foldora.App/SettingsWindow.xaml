<Window x:Class="Foldora.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="360"
        Height="260"
        MinWidth="320"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Настройки"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,18" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="Язык приложения:"
                       Margin="0,0,0,8" />
            <ComboBox ItemsSource="{Binding AvailableLanguages}"
                      SelectedValue="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Code"
                      DisplayMemberPath="DisplayName"
                      Width="180"
                      HorizontalAlignment="Left" />
            <TextBlock Text="Некоторые изменения языка могут применяться после перезапуска."
                       TextWrapping="Wrap"
                       Foreground="#555555"
                       Margin="0,10,0,0" />
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       Foreground="#2E6B2E"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Margin="0,10,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    MinWidth="96"
                    Padding="12,5"
                    Margin="0,0,8,0" />
            <Button Content="Закрыть"
                    Click="OnCloseClick"
                    MinWidth="96"
                    Padding="12,5" />
        </StackPanel>
    </Grid>
</Window>
