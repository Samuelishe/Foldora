<Window x:Class="Foldora.App.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding L.HelpWindowTitle}"
        Width="680"
        Height="620"
        MinWidth="560"
        MinHeight="420"
        SizeToContent="Manual"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource PageBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="{DynamicResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PageHeaderContainerStyle}">
            <StackPanel>
            <TextBlock Text="{Binding L.HelpWindowTitle}"
                       Style="{StaticResource PageTitleTextStyle}" />
            <TextBlock Text="{Binding L.HelpAboutSummary}"
                       Style="{StaticResource SecondaryBodyTextStyle}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,18,0">
                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L.HelpWhatFoldoraDoesTitle}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding L.HelpWhatFoldoraDoesBody}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L.HelpHowToUseTitle}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <Border Style="{StaticResource HelpStepContainerStyle}">
                            <TextBlock Text="{Binding L.HelpUseStepAddEntry}"
                                       Style="{StaticResource HelpStepTextStyle}" />
                        </Border>
                        <Border Style="{StaticResource HelpStepContainerStyle}">
                            <TextBlock Text="{Binding L.HelpUseStepChooseIcon}"
                                       Style="{StaticResource HelpStepTextStyle}" />
                        </Border>
                        <Border Style="{StaticResource HelpStepContainerStyle}">
                            <TextBlock Text="{Binding L.HelpUseStepSetNames}"
                                       Style="{StaticResource HelpStepTextStyle}" />
                        </Border>
                        <Border Style="{StaticResource HelpStepContainerStyle}">
                            <TextBlock Text="{Binding L.HelpUseStepSave}"
                                       Style="{StaticResource HelpStepTextStyle}" />
                        </Border>
                        <Border Style="{StaticResource HelpStepContainerStyle}">
                            <TextBlock Text="{Binding L.HelpUseStepEnableExplorer}"
                                       Style="{StaticResource HelpStepTextStyle}" />
                        </Border>
                        <Border Style="{StaticResource HelpStepContainerStyle}"
                                Margin="0">
                            <TextBlock Text="{Binding L.HelpUseStepUseExplorer}"
                                       Style="{StaticResource HelpStepTextStyle}" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L.HelpWhereMenuAppearsTitle}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding L.HelpWhereMenuAppearsLegacy}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding L.HelpWhereMenuAppearsHKCU}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L.HelpMenuHostTitle}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding L.HelpMenuHostBody}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L.HelpDataInstallTitle}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding L.HelpDataInstallBinaries}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding L.HelpDataInstallUserData}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding L.HelpDataInstallIcons}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L.HelpUninstallTitle}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding L.HelpUninstallBody}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="{Binding L.HelpUninstallUserDataWarning}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding L.HelpLicenseTitle}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding L.HelpLicenseBody}"
                                   Style="{StaticResource BodyTextStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding VersionText}"
                                   Style="{StaticResource CaptionTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"
                                   Visibility="{Binding HasVersion, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{Binding L.Close}"
                    Click="OnCloseClick"
                    Style="{StaticResource SecondaryButtonStyle}"
                    MinWidth="96" />
        </StackPanel>
    </Grid>
</Window>
